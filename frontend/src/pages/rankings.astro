---
import AppLayout from "../layouts/AppLayout.astro"
---

<AppLayout title="Rankings" active="rankings">
  <section class="page-heading rankings-heading">
    <div><h1>Rankings</h1><p>Explore the top players in World Cup 2026 across key performance metrics.</p></div>
  </section>

  <section class="table-card ranking-card" aria-live="polite">
    <table>
      <thead><tr>
        <th>Rank</th>
        <th aria-sort="none"><button class="table-sort" type="button" data-sort="player">Player <span class="sort-indicator" aria-hidden="true">↕</span></button></th>
        <th aria-sort="none"><button class="table-sort" type="button" data-sort="team">Team <span class="sort-indicator" aria-hidden="true">↕</span></button></th>
        <th aria-sort="none"><button class="table-sort" type="button" data-sort="matches">Matches Played <span class="sort-indicator" aria-hidden="true">↕</span></button></th>
        <th aria-sort="descending"><button class="table-sort" type="button" data-sort="goals">Total Goals <span class="sort-indicator" aria-hidden="true">↓</span></button></th>
        <th aria-sort="none"><button class="table-sort" type="button" data-sort="assists">Total Assists <span class="sort-indicator" aria-hidden="true">↕</span></button></th>
        <th aria-sort="none"><button class="table-sort" type="button" data-sort="rating">Rating <span class="sort-indicator" aria-hidden="true">↕</span></button></th>
      </tr></thead>
      <tbody id="ranking-rows"><tr><td colspan="7" class="loading-row">Loading rankings…</td></tr></tbody>
    </table>
  </section>
</AppLayout>

<script>
  const apiUrl = "http://localhost:3001/api"
  const rows = document.querySelector<HTMLTableSectionElement>("#ranking-rows")!
  const sortButtons = document.querySelectorAll<HTMLButtonElement>(".table-sort")
  let sortBy = "goals"
  let sortOrder: "asc" | "desc" = "desc"
  const initials = (name: string) => name.split(" ").slice(0, 2).map((part) => part[0]).join("")

  function updateSortControls() {
    for (const button of sortButtons) {
      const isActive = button.dataset.sort === sortBy
      const indicator = button.querySelector<HTMLElement>(".sort-indicator")!
      const header = button.closest("th")!

      header.setAttribute("aria-sort", isActive ? (sortOrder === "asc" ? "ascending" : "descending") : "none")
      indicator.textContent = isActive ? (sortOrder === "asc" ? "↑" : "↓") : "↕"
    }
  }

  async function loadRankings() {
    rows.innerHTML = `<tr><td colspan="7" class="loading-row">Loading rankings…</td></tr>`
    const response = await fetch(`${apiUrl}/rankings?sortBy=${sortBy}&sortOrder=${sortOrder}`)
    const { data } = await response.json()
    rows.innerHTML = ""
    data.forEach((player: Record<string, string>, index: number) => {
      const row = document.createElement("tr")
      row.innerHTML = `<td class="rank-number">${index + 1}</td><td><span class="avatar rank-avatar">${initials(player.player_name)}</span><span class="player-name"><b>${player.player_name}</b><small>${player.team}</small></span></td><td>${player.team}</td><td>${player.matches_played}</td><td class="total">${player.total_goals}</td><td>${player.total_assists}</td><td><span class="rating">${player.average_rating}</span></td>`
      rows.append(row)
    })
  }
  for (const button of sortButtons) {
    button.addEventListener("click", () => {
      if (button.dataset.sort === sortBy) sortOrder = sortOrder === "asc" ? "desc" : "asc"
      else {
        sortBy = button.dataset.sort!
        sortOrder = "asc"
      }
      updateSortControls()
      loadRankings()
    })
  }
  updateSortControls()
  loadRankings()
</script>
